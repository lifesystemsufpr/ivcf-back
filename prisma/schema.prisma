generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String     @id @default(uuid())
  email               String     @unique
  fullName            String
  fullName_normalized String     @default("") @db.Text
  password            String
  active              Boolean    @default(true)
  role                SystemRole

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  healthProfessional HealthProfessional?
  participant        Participant?
  researcher         Researcher?

  @@index([fullName_normalized])
  @@map("user")
}

model Researcher {
  id            String  @id @unique
  institutionId String
  fieldOfStudy  String?
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user        User        @relation(fields: [id], references: [id])

  @@index([institutionId])
  @@map("researcher")
}

model HealthProfessional {
  id                    String  @id @unique
  active                Boolean @default(true)
  speciality            String
  speciality_normalized String  @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  appliedQuestionnaires QuestionnaireResponse[]
  user                  User @relation(fields: [id], references: [id])

  participantsLinks HealthProfessionalParticipant[]

  @@index([speciality])
  @@index([speciality_normalized])
  @@index([active])
  @@map("health_professional")
}

model Participant {
  id           String   @id @unique
  birthday     DateTime @db.Date
  weight       Int      @default(0)
  height       Int      @default(0)
  zipCode      String
  street       String
  number       String
  complement   String?
  city         String
  state        String
  neighborhood String
  active       Boolean  @default(true)
  gender       Gender

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  questionnaireResponses QuestionnaireResponse[]
  user                   User @relation(fields: [id], references: [id])

  healthProfessionalsLinks HealthProfessionalParticipant[]

  @@map("participant")
}

model HealthProfessionalParticipant {
  healthProfessionalId String
  participantId        String

  createdAt DateTime @default(now())

  healthProfessional HealthProfessional @relation(fields: [healthProfessionalId], references: [id], onDelete: Cascade)
  participant        Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@id([healthProfessionalId, participantId])
  @@index([participantId])
  @@map("health_professional_participant")
}

model Questionnaire {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String? @db.Text
  active      Boolean @default(true)
  version     String  @default("1.0")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups    QuestionGroup[]
  responses QuestionnaireResponse[]

  @@map("questionnaire")
}

model QuestionGroup {
  id          String  @id @default(uuid())
  title       String
  order       Int
  description String? @db.Text

  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  subGroups QuestionSubGroup[]
  questions Question[]

  @@index([questionnaireId])
  @@map("question_group")
}

model QuestionSubGroup {
  id          String  @id @default(uuid())
  title       String
  order       Int
  description String? @db.Text

  groupId String
  group   QuestionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  questions Question[]

  @@index([groupId])
  @@map("question_subgroup")
}

model Question {
  id        String       @id @default(uuid())
  statement String       @db.Text
  order     Int
  type      QuestionType
  required  Boolean      @default(true)

  groupId String?
  group   QuestionGroup? @relation(fields: [groupId], references: [id])

  subGroupId String?
  subGroup   QuestionSubGroup? @relation(fields: [subGroupId], references: [id])

  options QuestionOption[]
  answers Answer[]

  @@map("question")
}

model QuestionOption {
  id    String @id @default(uuid())
  label String
  score Int    @default(0)
  order Int

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answers Answer[]

  @@index([questionId])
  @@map("question_option")
}

model QuestionnaireResponse {
  id String @id @default(uuid())

  totalScore     Int      @default(0)
  classification String?
  date           DateTime @default(now())

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  healthProfessionalId String
  healthProfessional   HealthProfessional @relation(fields: [healthProfessionalId], references: [id])

  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id])

  answers Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
  @@index([healthProfessionalId])
  @@map("questionnaire_response")
}

model Answer {
  id String @id @default(uuid())

  questionnaireResponseId String
  questionnaireResponse   QuestionnaireResponse @relation(fields: [questionnaireResponseId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptionId String?
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  valueText String?

  @@index([questionnaireResponseId])
  @@map("answer")
}

enum QuestionType {
  TEXT
  NUMBER
  BOOLEAN
  MULTIPLE_CHOICE
  SCALE
}

enum SystemRole {
  MANAGER
  PARTICIPANT
  RESEARCHER
  HEALTH_PROFESSIONAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
