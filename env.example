# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/tecno_aging_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Application Configuration
PORT=3000
NODE_ENV=production

# HTTPS Configuration (optional - for direct HTTPS without Nginx)
HTTPS_ENABLED=false
SSL_KEY_PATH=/path/to/private-key.pem
SSL_CERT_PATH=/path/to/certificate.pem

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# API Configuration
API_PREFIX="api"
API_VERSION="v1"

# Logging Configuration
LOG_LEVEL="info"

# Security Configuration
BCRYPT_ROUNDS=12

# Swagger Configuration (for development)
SWAGGER_ENABLED=false
SWAGGER_PATH="backend/api-docs"

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
# Memory thresholds (in MB) for Terminus
HEALTH_HEAP_LIMIT_MB=200
HEALTH_RSS_LIMIT_MB=300
# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@tecnoaging.com"
SMTP_FROM_NAME="TecnoAging"

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"